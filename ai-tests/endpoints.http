@baseUrl = http://localhost:8000/api
@tableName = planetary_data

### 1. Health Check
# Verify the backend server is running
GET {{baseUrl}}/health
Accept: application/json

### 2. Get Database Schema
# Retrieve the list of documented tables and their descriptions
GET {{baseUrl}}/database/schema
Accept: application/json

### 3. Inspect Table Data
# Fetch all records (up to internal cap) from a specific table (e.g. planetary_data)
GET {{baseUrl}}/database/{{tableName}}
Accept: application/json

### 4. Upload CSV/Excel Data (Requires multipart/form-data)
# Agents testing file uploads can use this reference payload structure
POST {{baseUrl}}/database/upload
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="test_data.csv"
Content-Type: text/csv

id,name,value
1,Item A,100
2,Item B,200
------WebKitFormBoundary7MA4YWxkTrZu0gW--

### 5. Generate SQL Query
# Test the AI SQL generation endpoint
POST {{baseUrl}}/generate
Content-Type: application/json
Accept: application/json

{
    "prompt": "Show me the top 5 most expensive products in the ecommerce table."
}
