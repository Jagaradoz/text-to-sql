meta {
  name: Generate SQL
  type: http
  seq: 1
}

post {
  url: http://localhost:8000/api/generate
  body: json
  auth: none
}

headers {
  x-ai-api-key: {{openai_api_key}}
}

body:json {
  {
    "prompt": "Show the top 10 most recent orders",
    "provider": "openai",
    "model_name": "gpt-4o-mini"
  }
  
}

docs {
  Invokes the LangChain agent to generate and execute SQL based on the provided prompt.
  
  Important Settings:
  - provider: Set to "openai" (default) or "ollama".
  - model_name: (Optional) Set to specify the exact model, e.g. "gpt-4o" or "llama3.1".
  
  Make sure to replace YOUR_API_KEY_HERE with your actual OpenAI API key in the headers if using OpenAI.
}
